---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import { getGithubActivity } from "../lib/github";
import { posts } from "../lib/data";
import { env } from "cloudflare:workers";
import Link from "../components/Link.astro";

const kv = (env as any).SESSION;
const activityCards = await getGithubActivity(kv);

const feed = [...posts, ...activityCards]
  .filter((item) => !!item.date)
  .sort((a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime());
---

<Layout title="home">
  <h1 class="mb-4">atelier</h1>
  <p>
    hey, I'm mcVyp. <strong>software engineer</strong> who likes to help. I build
    for fun and contribute to open source when I can.
  </p>
  <p>
    focused on improving my craft and building things worth using. learning <strong
      >French</strong
    > and <strong>German</strong> on the side. slowly, but consistently.
  </p>
  <div class="text-[1.6rem] font-bold">
    <Link href="/work" label="see work →" />
  </div>

  <section class="mt-10">
    <h4 class="text-zinc-500 dark:text-zinc-400 mb-10">right now</h4>
    <div class="relative">
      <div class="max-h-[40vh] overflow-y-auto">
        {feed.map((item) => <Card {...item} />)}
      </div>
      <div
        class="pointer-events-none absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent dark:from-[var(--color-bg-dark)]"
      >
      </div>
    </div>
  </section>
</Layout>
