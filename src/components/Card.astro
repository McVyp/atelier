---
interface Props {
  title: string;
  role?: string;
  description?: string;
  date?: string;
  slug?: string;
  href?: string;
  type?: 'post' | 'activity' | 'work';
}
const { title, role, description, date, slug, href, type } = Astro.props;
const url = slug ? `/blog/${slug}` : href ?? '#';
const external = !!href;
---

<a 
  href={url}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={`block ${type === 'activity' ? 'pointer-events-none cursor-default' : ''}`}
>
  <div class="flex justify-between items-baseline">
    {type === 'post' || type === 'activity'
      ? <div class="flex w-full py-4">
          <h4 class="w-1/2 truncate hover:underline underline-offset-4">{title}</h4>
          <span class="w-1/2 text-[1.4rem] truncate">{description}</span>
        </div>
      : type === 'work'
      ? <div class="flex flex-col w-full gap-1">
          <div class="flex justify-between">
            <h4 class="hover:underline underline-offset-4 text-[1.8rem] lowercase">{title}</h4>
            <span class="text-zinc-500 text-[1.4rem]">{date}</span>
          </div>
          {role && <p class="text-[1.4rem] text-zinc-500">{role}</p>}
          {description && <p class="text-[1.4rem]">{description}</p>}
        </div>
      : <>
          <div>
            <h4 class="hover:underline underline-offset-4">{title}</h4>
            <p class="text-[1.4rem] line-clamp-1">{description}</p>
          </div>
          <span class="self-end">{date}</span>
        </>
    }
  </div>
</a>