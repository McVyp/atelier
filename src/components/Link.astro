---
interface Props {
  href: string;
  label?: string;
  icon?: string;
  external?: boolean;
}
const { href, label, icon, external = false } = Astro.props;
const isActive = !external && Astro.url.pathname === href && href !== '/';
---
<a 
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={`hover:underline underline-offset-4 ${isActive ? 'underline' : 'no-underline'}`}
>
  {icon ? <img src={icon} alt={label} /> : label}
</a>