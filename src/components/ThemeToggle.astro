---

---

<button
  id="theme-toggle"
  type="button"
  aria-label="toggle theme"
  class="flex items-center justify-center w-5 h-5 hover:opacity-60 transition-opacity hover:cursor-pointer"
>
  <svg
    id="icon-sun"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <svg
    id="icon-moon"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  function updateIcons(isDark: boolean) {
    const sun = document.getElementById("icon-sun") as HTMLElement;
    const moon = document.getElementById("icon-moon") as HTMLElement;
    if (sun) sun.style.display = isDark ? "block" : "none";
    if (moon) moon.style.display = isDark ? "none" : "block";
  }

  function initIcons() {
    const saved = localStorage.getItem("theme");
    const isDark = saved
      ? saved === "dark"
      : window.matchMedia("(prefers-color-scheme: dark)").matches;
    updateIcons(isDark);
  }

  function handleToggle() {
    const dark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", dark ? "dark" : "light");
    updateIcons(dark);
  }

  document.addEventListener("astro:after-swap", initIcons);
  document.addEventListener("astro:page-load", () => {
    initIcons();
    const btn = document.getElementById("theme-toggle");
    btn?.removeEventListener("click", handleToggle);
    btn?.addEventListener("click", handleToggle);
  });
</script>
